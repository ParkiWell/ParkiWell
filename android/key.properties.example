# Keystore configuration for release builds
# Copy this file to key.properties and fill in your values
# DO NOT commit key.properties to version control!

# To generate a keystore, run:
# keytool -genkey -v -keystore ~/parkiwell-release-key.jks -keyalg RSA -keysize 2048 -validity 10000 -alias parkiwell

storePassword=YOUR_KEYSTORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=parkiwell
storeFile=/path/to/your/parkiwell-release-key.jks
